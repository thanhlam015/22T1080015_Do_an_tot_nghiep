@model IEnumerable<_22T1080015_Do_an_tot_nghiep.Models.StaffListItemVM>

@{
    ViewData["Title"] = "Nhân viên";
    Layout = "_LayoutAdmin";

    string selectedRole = Convert.ToString(ViewBag.Role);
    string selectedStatus = Convert.ToString(ViewBag.Status);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-secondary mb-0">
        <i class="fa-solid fa-user-tie text-primary me-2"></i> Nhân viên
    </h4>

    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Thêm nhân viên
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-1"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-xmark me-1"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <input type="text"
                       name="keyword"
                       value="@ViewBag.Keyword"
                       class="form-control"
                       placeholder="Tìm tên, email, số điện thoại..." />
            </div>

            <div class="col-md-2">
                <select name="role" class="form-select">
                    <option value="">Tất cả vai trò</option>
                    <option value="Admin" selected="@(selectedRole == "Admin" ? "selected" : null)">Quản trị viên</option>
                    <option value="Staff" selected="@(selectedRole == "Staff" ? "selected" : null)">Nhân viên</option>
                </select>
            </div>

            <div class="col-md-2">
                <select name="status" class="form-select">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Active" selected="@(selectedStatus == "Active" ? "selected" : null)">Hoạt động</option>
                    <option value="Inactive" selected="@(selectedStatus == "Inactive" ? "selected" : null)">Ngưng hoạt động</option>
                    <option value="Locked" selected="@(selectedStatus == "Locked" ? "selected" : null)">Đã khóa</option>
                </select>
            </div>

            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-secondary">
                    <i class="fa-solid fa-filter me-1"></i> Lọc
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-rotate-left me-1"></i> Xóa lọc
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Nhân viên</th>
                        <th>Liên hệ</th>
                        <th>Vai trò</th>
                        <th>Trạng thái</th>
                        <th>Hoạt động</th>
                        <th class="text-end pe-3">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold">#@item.UserId</td>

                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrWhiteSpace(item.AvatarUrl))
                                        {
                                            <img src="@item.AvatarUrl"
                                                 alt="@item.FullName"
                                                 class="me-3 shadow-sm"
                                                 style="width:45px; height:45px; border-radius:50%; object-fit:cover; border:2px solid #dee2e6;" />
                                        }
                                        else
                                        {
                                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3"
                                                 style="width:45px; height:45px; font-weight:bold;">
                                                @item.Initials
                                            </div>
                                        }

                                        <div>
                                            <div class="fw-bold">@item.FullName</div>
                                            <small class="text-muted">Tạo: @item.CreatedAt.ToString("dd/MM/yyyy")</small>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <div>
                                        <i class="fa-regular fa-envelope text-muted me-1"></i>
                                        @item.Email
                                    </div>

                                    <div>
                                        <i class="fa-solid fa-phone text-muted me-1"></i>
                                        @item.PhoneNumber
                                    </div>
                                </td>

                                <td>
                                    @if (item.Role == "Admin")
                                    {
                                        <span class="badge bg-danger">
                                            <i class="fa-solid fa-user-shield me-1"></i> Quản trị viên
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">
                                            <i class="fa-solid fa-user-tie me-1"></i> Nhân viên
                                        </span>
                                    }
                                </td>

                                <td>
                                    @if (item.IsLocked)
                                    {
                                        <span class="badge bg-dark">
                                            <i class="fa-solid fa-lock me-1"></i> Đã khóa
                                        </span>
                                    }
                                    else if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success">
                                            <i class="fa-solid fa-circle-check me-1"></i> Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="fa-solid fa-circle-pause me-1"></i> Ngưng hoạt động
                                        </span>
                                    }
                                </td>

                                <td>
                                    @if (item.LastLoginAt != null)
                                    {
                                        <small class="text-muted">
                                            Đăng nhập gần nhất:<br />
                                            @item.LastLoginAt.Value.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Chưa đăng nhập</small>
                                    }
                                </td>

                                <td class="text-end pe-3">
                                    <div class="btn-group">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.UserId"
                                           class="btn btn-sm btn-light text-primary"
                                           title="Sửa">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>

                                        <form asp-action="ToggleLock"
                                              asp-route-id="@item.UserId"
                                              method="post"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            @if (item.IsLocked)
                                            {
                                                <button type="submit"
                                                        class="btn btn-sm btn-light text-success"
                                                        onclick="return confirm('Mở khóa tài khoản này?')"
                                                        title="Mở khóa">
                                                    <i class="fa-solid fa-unlock"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit"
                                                        class="btn btn-sm btn-light text-danger"
                                                        onclick="return confirm('Khóa tài khoản này?')"
                                                        title="Khóa">
                                                    <i class="fa-solid fa-lock"></i>
                                                </button>
                                            }
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                Không tìm thấy nhân viên phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-4 pb-3">
                <ul class="pagination justify-content-center mb-0">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                                   page = i,
                                   keyword = ViewBag.Keyword,
                                   role = ViewBag.Role,
                                   status = ViewBag.Status
                               })">
                                @i
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>