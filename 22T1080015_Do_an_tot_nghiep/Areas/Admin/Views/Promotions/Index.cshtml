@model IEnumerable<_22T1080015_Do_an_tot_nghiep.Models.Promotion>

@{
    ViewData["Title"] = "Khuyến mãi";
    Layout = "_LayoutAdmin";

    string selectedStatus = Convert.ToString(ViewBag.Status);
    string selectedDiscountType = Convert.ToString(ViewBag.DiscountType);
}

@functions {
    string GetDiscountText(_22T1080015_Do_an_tot_nghiep.Models.Promotion item)
    {
        if (item.DiscountType == "Percent")
        {
            return $"{item.DiscountValue:N0}%";
        }

        return $"{item.DiscountValue:N0}đ";
    }

    string GetStatusText(_22T1080015_Do_an_tot_nghiep.Models.Promotion item)
    {
        var now = DateTime.Now;

        if (item.Status == "Inactive")
        {
            return "Đang tắt";
        }

        if (item.StartDate > now)
        {
            return "Sắp diễn ra";
        }

        if (item.EndDate < now)
        {
            return "Hết hạn";
        }

        return "Đang hoạt động";
    }

    string GetStatusBadge(_22T1080015_Do_an_tot_nghiep.Models.Promotion item)
    {
        var now = DateTime.Now;

        if (item.Status == "Inactive")
        {
            return "bg-secondary";
        }

        if (item.StartDate > now)
        {
            return "bg-info";
        }

        if (item.EndDate < now)
        {
            return "bg-danger";
        }

        return "bg-success";
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-secondary mb-0">
        <i class="fa-solid fa-percent text-primary me-2"></i> Khuyến mãi
    </h4>

    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Thêm khuyến mãi
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-1"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-xmark me-1"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <input type="text"
                       name="keyword"
                       value="@ViewBag.Keyword"
                       class="form-control"
                       placeholder="Tìm mã hoặc tên khuyến mãi..." />
            </div>

            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Active" selected="@(selectedStatus == "Active" ? "selected" : null)">Đang hoạt động</option>
                    <option value="Scheduled" selected="@(selectedStatus == "Scheduled" ? "selected" : null)">Sắp diễn ra</option>
                    <option value="Expired" selected="@(selectedStatus == "Expired" ? "selected" : null)">Hết hạn</option>
                    <option value="Inactive" selected="@(selectedStatus == "Inactive" ? "selected" : null)">Đang tắt</option>
                </select>
            </div>

            <div class="col-md-2">
                <select name="discountType" class="form-select">
                    <option value="">Loại giảm</option>
                    <option value="Percent" selected="@(selectedDiscountType == "Percent" ? "selected" : null)">Phần trăm</option>
                    <option value="Amount" selected="@(selectedDiscountType == "Amount" ? "selected" : null)">Số tiền</option>
                </select>
            </div>

            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-secondary">
                    <i class="fa-solid fa-filter me-1"></i> Lọc
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-rotate-left me-1"></i> Xóa lọc
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-3">Khuyến mãi</th>
                        <th>Mã</th>
                        <th>Giảm giá</th>
                        <th>Thời gian</th>
                        <th>Phạm vi</th>
                        <th>Lượt dùng</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-3">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrWhiteSpace(item.BannerImageUrl))
                                        {
                                            <img src="@item.BannerImageUrl"
                                                 class="rounded border me-3"
                                                 style="width:80px; height:50px; object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <div class="bg-light border rounded d-flex align-items-center justify-content-center me-3"
                                                 style="width:80px; height:50px;">
                                                <i class="fa-solid fa-image text-muted"></i>
                                            </div>
                                        }

                                        <div>
                                            <div class="fw-bold">@item.Title</div>
                                            <small class="text-muted">
                                                @(string.IsNullOrWhiteSpace(item.Description) ? "Không có mô tả" : item.Description)
                                            </small>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="badge bg-dark">@item.Code</span>
                                </td>

                                <td>
                                    <div class="fw-bold text-danger">
                                        @GetDiscountText(item)
                                    </div>

                                    @if (item.MaxDiscountAmount != null)
                                    {
                                        <small class="text-muted">
                                            Tối đa @item.MaxDiscountAmount.Value.ToString("N0")đ
                                        </small>
                                    }

                                    @if (item.MinBookingAmount > 0)
                                    {
                                        <br />
                                        <small class="text-muted">
                                            Đơn từ @item.MinBookingAmount.ToString("N0")đ
                                        </small>
                                    }
                                </td>

                                <td>
                                    <div>@item.StartDate.ToString("dd/MM/yyyy HH:mm")</div>
                                    <small class="text-muted">
                                        đến @item.EndDate.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                </td>

                                <td>
                                    @if (item.PromotionAccommodations != null && item.PromotionAccommodations.Any())
                                    {
                                        <span class="badge bg-light text-dark border">
                                            @item.PromotionAccommodations.Count nơi lưu trú
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">
                                            Tất cả nơi lưu trú
                                        </span>
                                    }
                                </td>

                                <td>
                                    <strong>@item.UsedCount</strong>
                                    /
                                    @(item.UsageLimit?.ToString() ?? "∞")
                                </td>

                                <td>
                                    <span class="badge @GetStatusBadge(item)">
                                        @GetStatusText(item)
                                    </span>
                                </td>

                                <td class="text-end pe-3">
                                    <div class="btn-group">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-light text-primary"
                                           title="Sửa">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>

                                        <form asp-action="ToggleStatus"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            @if (item.Status == "Active")
                                            {
                                                <button type="submit"
                                                        class="btn btn-sm btn-light text-warning"
                                                        title="Tắt khuyến mãi">
                                                    <i class="fa-solid fa-toggle-off"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit"
                                                        class="btn btn-sm btn-light text-success"
                                                        title="Bật khuyến mãi">
                                                    <i class="fa-solid fa-toggle-on"></i>
                                                </button>
                                            }
                                        </form>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-light text-danger"
                                           title="Xóa">
                                            <i class="fa-solid fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">
                                Không tìm thấy khuyến mãi phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="_AdminPagination" />
    </div>
</div>