@model _22T1080015_Do_an_tot_nghiep.Models.BookingNotificationVM

<div class="dropdown">
    <div class="notification-bell" data-bs-toggle="dropdown" aria-expanded="false">
        <i class="fa-solid fa-bell"></i>

        @if (Model.PendingCount > 0)
        {
            <div class="notification-dot"></div>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="font-size: 10px;">
                @Model.PendingCount
            </span>
        }
    </div>

    <ul class="dropdown-menu dropdown-menu-end shadow" style="width: 360px;">
        <li class="dropdown-header d-flex justify-content-between align-items-center">
            <span>Thông báo đặt phòng</span>

            @if (Model.PendingCount > 0)
            {
                <span class="badge bg-danger">@Model.PendingCount mới</span>
            }
        </li>

        <li><hr class="dropdown-divider" /></li>

        @if (Model.Items.Any())
        {
            foreach (var item in Model.Items)
            {
                <li>
                    <a asp-area="Admin"
                       asp-controller="Bookings"
                       asp-action="Details"
                       asp-route-id="@item.Id"
                       class="dropdown-item small py-2">
                        <div class="fw-bold">
                            Đơn mới #@item.Id - @item.CustomerName
                        </div>

                        <div class="text-muted">
                            @item.AccommodationName
                        </div>

                        <div class="d-flex justify-content-between mt-1">
                            <span class="text-danger fw-bold">
                                @item.TotalPrice.ToString("N0")đ
                            </span>

                            <span class="text-muted">
                                @item.CreatedAt.ToString("dd/MM HH:mm")
                            </span>
                        </div>
                    </a>
                </li>
            }
        }
        else
        {
            <li class="px-3 py-3 text-center text-muted small">
                Không có đơn đặt phòng mới.
            </li>
        }

        <li><hr class="dropdown-divider" /></li>

        <li>
            <a asp-area="Admin"
               asp-controller="Bookings"
               asp-action="Index"
               asp-route-status="Pending"
               class="dropdown-item text-center fw-bold text-primary">
                Xem tất cả đơn chờ xác nhận
            </a>
        </li>
    </ul>
</div>