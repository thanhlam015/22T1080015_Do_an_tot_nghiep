@model IEnumerable<_22T1080015_Do_an_tot_nghiep.Models.RagDocument>

@{
    ViewData["Title"] = "Quản lý Vector DB";
    Layout = "_LayoutAdmin";

    string selectedSource = Convert.ToString(ViewBag.SourceTable);
    string selectedStatus = Convert.ToString(ViewBag.Status);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold text-secondary mb-0">
        <i class="fa-solid fa-database text-primary me-2"></i> Quản lý Vector DB
    </h4>

    <form asp-action="SyncAll" method="post">
        @Html.AntiForgeryToken()
        <button type="submit"
                class="btn btn-primary shadow-sm"
                onclick="return confirm('Đồng bộ lại toàn bộ dữ liệu công khai vào Vector DB?')">
            <i class="fa-solid fa-rotate me-1"></i> Đồng bộ toàn bộ
        </button>
    </form>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fa-solid fa-circle-check me-1"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["InfoMessage"] != null)
{
    <div class="alert alert-info alert-dismissible fade show">
        <i class="fa-solid fa-circle-info me-1"></i> @TempData["InfoMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fa-solid fa-circle-xmark me-1"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <small class="text-muted">Tài liệu AI</small>
                <h3 class="fw-bold mb-0">@ViewBag.TotalDocuments</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <small class="text-muted">Chunks</small>
                <h3 class="fw-bold mb-0">@ViewBag.TotalChunks</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <small class="text-muted">Nơi lưu trú đã index</small>
                <h3 class="fw-bold text-success mb-0">@ViewBag.IndexedAccommodations</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <small class="text-muted">Lỗi AI</small>
                <h3 class="fw-bold text-danger mb-0">@ViewBag.ErrorAccommodations</h3>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-2 align-items-center">
            <div class="col-md-4">
                <input type="text"
                       name="keyword"
                       value="@ViewBag.Keyword"
                       class="form-control"
                       placeholder="Tìm tiêu đề tài liệu AI..." />
            </div>

            <div class="col-md-3">
                <select name="sourceTable" class="form-select">
                    <option value="">Tất cả nguồn</option>
                    <option value="Accommodations" selected="@(selectedSource == "Accommodations" ? "selected" : null)">Nơi lưu trú</option>
                    <option value="Promotions" selected="@(selectedSource == "Promotions" ? "selected" : null)">Khuyến mãi</option>
                </select>
            </div>

            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Indexed" selected="@(selectedStatus == "Indexed" ? "selected" : null)">Đã index</option>
                    <option value="Error" selected="@(selectedStatus == "Error" ? "selected" : null)">Lỗi</option>
                    <option value="Indexing" selected="@(selectedStatus == "Indexing" ? "selected" : null)">Đang index</option>
                </select>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-secondary">
                    <i class="fa-solid fa-filter"></i>
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-rotate-left"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary">
                <tr>
                    <th class="ps-3">Tài liệu</th>
                    <th>Nguồn</th>
                    <th>Chunks</th>
                    <th>Trạng thái</th>
                    <th>Lần index</th>
                    <th class="text-end pe-3">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3">
                                <div class="fw-bold">@item.Title</div>
                                <small class="text-muted">#@item.Id</small>
                            </td>

                            <td>
                                <span class="badge bg-light text-dark border">
                                    @item.SourceTable #@item.SourceId
                                </span>
                            </td>

                            <td>
                                <strong>@item.RagChunks.Count</strong>
                            </td>

                            <td>
                                @if (!item.IsActive)
                                {
                                    <span class="badge bg-secondary">Đã tắt</span>
                                }
                                else if (item.AiIndexStatus == "Indexed")
                                {
                                    <span class="badge bg-success">Đã index</span>
                                }
                                else if (item.AiIndexStatus == "Error")
                                {
                                    <span class="badge bg-danger">Lỗi</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@item.AiIndexStatus</span>
                                }
                            </td>

                            <td>
                                @(item.IndexedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chưa có")
                            </td>

                            <td class="text-end pe-3">
                                <div class="btn-group">
                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-light text-info">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>

                                    <form asp-action="ToggleActive"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          class="d-inline">
                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-sm btn-light @(item.IsActive ? "text-warning" : "text-success")">
                                            <i class="fa-solid @(item.IsActive ? "fa-toggle-off" : "fa-toggle-on")"></i>
                                        </button>
                                    </form>

                                    <form asp-action="Delete"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Xóa tài liệu này khỏi Vector DB?')">
                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="btn btn-sm btn-light text-danger">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">
                            Chưa có dữ liệu trong Vector DB.
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-4 pb-3">
                <ul class="pagination justify-content-center mb-0">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link"
                               href="@Url.Action("Index", new {
                                   page = i,
                                   keyword = ViewBag.Keyword,
                                   sourceTable = ViewBag.SourceTable,
                                   status = ViewBag.Status
                               })">
                                @i
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>