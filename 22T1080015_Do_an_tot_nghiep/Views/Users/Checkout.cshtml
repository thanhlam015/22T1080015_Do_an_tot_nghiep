@model _22T1080015_Do_an_tot_nghiep.Models.UserCheckoutVM

@{
    ViewData["Title"] = "Thanh toán";
    Layout = "_LayoutUser";
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="user-card p-4 mb-4">
            <h4 class="fw-bold mb-3">
                <i class="fa-solid fa-user-check text-primary me-2"></i>
                Thông tin người đặt
            </h4>

            <form asp-controller="Users" asp-action="Checkout" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="RoomId" />
                <input type="hidden" asp-for="AccommodationId" />
                <input type="hidden" asp-for="CheckInDate" />
                <input type="hidden" asp-for="CheckOutDate" />
                <input type="hidden" asp-for="RoomCount" />
                <input type="hidden" asp-for="AdultCount" />
                <input type="hidden" asp-for="ChildCount" />
                <input type="hidden" asp-for="PromotionCode" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Họ tên</label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Ghi chú</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"
                              placeholder="Ví dụ: muốn phòng tầng cao, đến trễ..."></textarea>
                </div>

                <h5 class="fw-bold mb-3">
                    <i class="fa-solid fa-credit-card text-primary me-2"></i>
                    Phương thức thanh toán
                </h5>

                <div class="payment-method-list mb-4">
                    <label class="payment-method-item">
                        <input type="radio"
                               name="PaymentMethod"
                               value="PayAtHotel"
                               checked="@(Model.PaymentMethod == "PayAtHotel" ? "checked" : null)" />

                        <div>
                            <strong>Thanh toán tiền mặt tại nơi lưu trú</strong>
                            <p class="text-muted mb-0">
                                Đơn sẽ ở trạng thái chờ xác nhận, thanh toán khi nhận phòng hoặc theo quy định nơi lưu trú.
                            </p>
                        </div>
                    </label>

                    <label class="payment-method-item">
                        <input type="radio"
                               name="PaymentMethod"
                               value="VietQR"
                               checked="@(Model.PaymentMethod == "VietQR" ? "checked" : null)" />

                        <div>
                            <strong>Chuyển khoản QR</strong>
                            <p class="text-muted mb-0">
                                Sau khi tạo đơn, hệ thống hiển thị mã QR. Admin sẽ xác nhận thanh toán sau khi kiểm tra giao dịch.
                            </p>
                        </div>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary rounded-pill fw-bold w-100 py-2">
                    Xác nhận đặt phòng
                </button>
            </form>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="user-card p-4 checkout-summary-card">
            <h4 class="fw-bold mb-3">Tóm tắt đặt phòng</h4>

            <div class="d-flex gap-3 mb-3">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="checkout-room-img" alt="@Model.RoomType" />
                }
                else
                {
                    <div class="image-placeholder checkout-room-img">
                        <i class="fa-solid fa-bed"></i>
                    </div>
                }

                <div>
                    <h5 class="fw-bold mb-1">@Model.AccommodationName</h5>
                    <div class="text-muted">@Model.RoomType</div>
                </div>
            </div>

            <div class="summary-row">
                <span>Ngày nhận</span>
                <strong>@Model.CheckInDate.ToString("dd/MM/yyyy")</strong>
            </div>

            <div class="summary-row">
                <span>Ngày trả</span>
                <strong>@Model.CheckOutDate.ToString("dd/MM/yyyy")</strong>
            </div>

            <div class="summary-row">
                <span>Số đêm</span>
                <strong>@Model.StayNights</strong>
            </div>

            <div class="summary-row">
                <span>Số phòng</span>
                <strong>@Model.RoomCount</strong>
            </div>

            <div class="summary-row">
                <span>Khách</span>
                <strong>@Model.AdultCount người lớn · @Model.ChildCount trẻ em</strong>
            </div>
            <div class="mt-3">
                <label class="form-label fw-semibold">Khuyến mãi</label>

                @if (Model.DiscountAmount > 0)
                {
                    <div class="alert alert-success mb-0">
                        <i class="fa-solid fa-tags me-1"></i>
                        @Model.PromotionMessage
                    </div>
                }
                else
                {
                    <div class="alert alert-light border mb-0 text-muted">
                        <i class="fa-solid fa-circle-info me-1"></i>
                        @Model.PromotionMessage
                    </div>
                }
            </div>

            <hr />

            @if (Model.DiscountAmount > 0)
            {
                <div class="summary-row">
                    <span>Giá gốc</span>
                    <strong>@Model.OriginalTotalPrice.ToString("N0")đ</strong>
                </div>

                <div class="summary-row text-success">
                    <span>Khuyến mãi</span>
                    <strong>-@Model.DiscountAmount.ToString("N0")đ</strong>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center">
                <span class="fw-bold">Tổng thanh toán</span>
                <strong class="text-danger fs-3">
                    @Model.TotalPrice.ToString("N0")đ
                </strong>
            </div>

            <small class="text-muted d-block mt-2">
                Giá đã tính theo số đêm và số phòng đã chọn.
            </small>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}