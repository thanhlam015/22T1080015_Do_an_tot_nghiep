@model _22T1080015_Do_an_tot_nghiep.Models.UserAccommodationCardVM

@{
    string returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 accommodation-card">
    <div class="position-relative">
        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl"
                 class="card-img-top accommodation-img"
                 alt="@Model.Name" />
        }
        else
        {
            <div class="image-placeholder accommodation-img">
                <i class="fa-solid fa-hotel fa-3x"></i>
            </div>
        }

        <form asp-controller="Users"
              asp-action="ToggleLike"
              asp-route-accommodationId="@Model.Id"
              method="post"
              class="m-0">
            @Html.AntiForgeryToken()

            <input type="hidden" name="returnUrl" value="@returnUrl" />

            <button type="submit"
                    class="like-floating-btn shadow-sm"
                    title="Lưu nơi lưu trú">
                @if (Model.IsSaved)
                {
                    <i class="fa-solid fa-heart"></i>
                }
                else
                {
                    <i class="fa-regular fa-heart"></i>
                }
            </button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.PromotionCode))
        {
            <span class="promotion-badge">
                @Model.PromotionCode
            </span>
        }
    </div>

    <div class="card-body">
        <h5 class="fw-bold mb-2 text-truncate">
            @Model.Name
        </h5>

        <div class="text-muted small mb-2">
            <i class="fa-solid fa-location-dot me-1"></i>
            @Model.DistrictName
        </div>

        <div class="text-muted small mb-3 text-truncate">
            @Model.Address
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.PromotionTitle))
        {
            <div class="small text-danger fw-semibold mb-2">
                <i class="fa-solid fa-tags me-1"></i>
                @Model.PromotionTitle
            </div>
        }

        <div class="d-flex justify-content-between align-items-end">
            <div>
                @if (Model.AverageRating != null)
                {
                    <span class="badge bg-primary">
                        <i class="fa-solid fa-star me-1"></i>@Model.AverageRating
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary">Mới</span>
                }

                <div class="small text-muted mt-1">
                    @Model.PropertyTypeName
                </div>
            </div>

            <div class="text-end">
                <small class="text-muted">Từ</small>
                <div class="fw-bold text-danger fs-5">
                    @Model.DisplayPrice.ToString("N0")đ
                </div>

                <small class="text-muted">
                    @Model.PriceSuffix
                </small>
            </div>
        </div>

        <a asp-controller="Users"
           asp-action="Details"
           asp-route-id="@Model.Id"
           class="btn btn-outline-primary rounded-pill w-100 fw-bold mt-3">
            Xem chi tiết
        </a>
    </div>
</div>